<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@color/read_dialog_bg"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:orientation="vertical">

    <!-- 播放控制行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/setting_height"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_tts_prev"
            style="@style/setting_dialog_button"
            android:layout_weight="1"
            android:text="上一章" />

        <TextView
            android:id="@+id/tv_tts_play"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="center"
            android:textColor="@color/read_dialog_button_select"
            android:textSize="20sp"
            android:text="▶ 播放" />

        <TextView
            android:id="@+id/tv_tts_next"
            style="@style/setting_dialog_button"
            android:layout_weight="1"
            android:text="下一章" />

    </LinearLayout>

    <!-- 语速选择行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/setting_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:text="语速" />

        <TextView
            android:id="@+id/tv_speed_075"
            style="@style/setting_dialog_button"
            android:layout_weight="1"
            android:text="0.75x" />

        <TextView
            android:id="@+id/tv_speed_100"
            style="@style/setting_dialog_button"
            android:layout_weight="1"
            android:text="1.0x" />

        <TextView
            android:id="@+id/tv_speed_150"
            style="@style/setting_dialog_button"
            android:layout_weight="1"
            android:text="1.5x" />

        <TextView
            android:id="@+id/tv_speed_200"
            style="@style/setting_dialog_button"
            android:layout_weight="1"
            android:text="2.0x" />

    </LinearLayout>

</LinearLayout>
