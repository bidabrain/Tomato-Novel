<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="3dp"
    app:cardBackgroundColor="#ffffff"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:cardUseCompatPadding="false">

    <RelativeLayout
        android:id="@+id/bookItemLinearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 封面图 -->
        <ImageView
            android:id="@+id/iv_cover"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/cover_default_new"
            android:contentDescription="封面" />

        <!-- 番茄原创徽章（封面右上角） -->
        <TextView
            android:id="@+id/v_tomato_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/iv_cover"
            android:layout_alignParentRight="true"
            android:layout_margin="3dp"
            android:background="#E5492C"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="番茄原创"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:visibility="gone" />

        <!-- 本地书标签（封面右上角，覆盖番茄徽章位置） -->
        <TextView
            android:id="@+id/tv_local_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/iv_cover"
            android:layout_alignParentRight="true"
            android:layout_margin="3dp"
            android:background="@color/color_local_badge"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="本地"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:visibility="gone" />

        <!-- 新章节 badge（封面左下角） -->
        <TextView
            android:id="@+id/tv_update_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@id/iv_cover"
            android:layout_alignParentLeft="true"
            android:background="#CCE5492C"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- 下载中遮罩 -->
        <TextView
            android:id="@+id/tv_downloading"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_alignTop="@id/iv_cover"
            android:background="#99000000"
            android:gravity="center"
            android:text="下载中…"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- 书名 + 进度文字 + 进度条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/iv_cover"
            android:orientation="vertical"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:paddingTop="4dp"
            android:paddingBottom="5dp">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:lines="2"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_msg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:lines="1"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />

            <!-- 进度条（轨道 + 填充） -->
            <FrameLayout
                android:id="@+id/fl_progress_bar"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="1dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/bg_progress_track" />

                <View
                    android:id="@+id/v_progress_fill"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:background="@color/colorPrimary" />

            </FrameLayout>

        </LinearLayout>

        <!-- 删除模式遮罩 -->
        <LinearLayout
            android:id="@+id/llt_del"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_alignTop="@id/iv_cover"
            android:background="#AA000000"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <View
                android:id="@+id/ib_del"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@mipmap/item_close_button" />
        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>
