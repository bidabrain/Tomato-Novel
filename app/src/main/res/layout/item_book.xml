<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="5dp"
    android:layout_marginRight="5dp"
    app:cardBackgroundColor="#ffffff"
    app:cardCornerRadius="2dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:id="@+id/bookItemLinearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="6dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_cover"
            android:layout_width="72dp"
            android:layout_height="96dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/cover_default_new"
            android:contentDescription="封面" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:lines="1"
                    android:textColor="#000000"
                    android:textSize="15sp" />

                <!-- Fanqie badge: only visible for isTomato=1 books -->
                <TextView
                    android:id="@+id/v_tomato_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="4dp"
                    android:background="#FFEB3B"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp"
                    android:text="番茄"
                    android:textColor="#E53935"
                    android:textSize="10sp"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_msg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:lines="4"
                android:lineSpacingExtra="2dp"
                android:textColor="#807e7e"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/llt_del"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_item_sel"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible">

            <View
                android:id="@+id/ib_del"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:background="@mipmap/item_close_button" />
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
