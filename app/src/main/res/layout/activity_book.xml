<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_album"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_activity"
    android:orientation="vertical">

    <include layout="@layout/layout_title" />

    <!-- 细分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0E8E4" />

    <!-- Tab content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- 书架 Tab -->
        <LinearLayout
            android:id="@+id/container_bookshelf"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- 问候语 -->
            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- 搜索栏 + 历史按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search"
                    android:drawableLeft="@android:drawable/ic_menu_search"
                    android:drawablePadding="8dp"
                    android:drawableTint="@color/text_hint"
                    android:hint="搜索书名…"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:singleLine="true"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/ib_history"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="4dp"
                    android:background="@drawable/bg_item_sel"
                    android:contentDescription="搜索历史"
                    android:scaleType="center"
                    android:src="@drawable/ic_history"
                    android:tint="@color/text_hint" />

            </LinearLayout>

            <!-- 联网检查新章节状态横条 -->
            <TextView
                android:id="@+id/tv_update_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF3E0"
                android:gravity="center"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:text="正在检查新章节…"
                android:textColor="#BF360C"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- 继续阅读 Banner 卡片（封面全屏填充 + 渐变叠加） -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_continue_banner"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- 全屏封面背景 -->
                    <ImageView
                        android:id="@+id/iv_banner_cover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="封面"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/cover_default_new" />

                    <!-- 渐变遮罩：左侧不透明 → 右侧透明 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_banner_gradient" />

                    <!-- 文字区域：左下角 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- 书名 -->
                        <TextView
                            android:id="@+id/tv_banner_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- 进度文字 -->
                        <TextView
                            android:id="@+id/tv_banner_progress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp" />

                        <!-- 进度条 -->
                        <FrameLayout
                            android:layout_width="160dp"
                            android:layout_height="3dp"
                            android:layout_marginTop="6dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="3dp"
                                android:background="#44FFFFFF" />

                            <View
                                android:id="@+id/v_banner_progress_fill"
                                android:layout_width="0dp"
                                android:layout_height="3dp"
                                android:background="#FFFFFF" />

                        </FrameLayout>

                    </LinearLayout>

                    <!-- 继续阅读按钮：右下角 -->
                    <TextView
                        android:id="@+id/btn_continue_read"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_marginBottom="14dp"
                        android:layout_marginRight="14dp"
                        android:background="@drawable/bg_read_btn_outline"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:text="继续阅读 →"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <!-- 统计数据行（本周阅读、累计天数、收藏书籍） -->
            <LinearLayout
                android:id="@+id/row_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_rounded"
                android:orientation="horizontal"
                android:padding="12dp"
                android:visibility="gone">

                <!-- 本周阅读 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription=""
                        android:src="@drawable/ic_time"
                        android:tint="#E5492C" />

                    <TextView
                        android:id="@+id/tv_stat_weekly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0分钟"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="本周阅读"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- 竖向分隔线 -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#F0E8E4" />

                <!-- 累计阅读天数 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription=""
                        android:src="@drawable/ic_calendar"
                        android:tint="#4CAF50" />

                    <TextView
                        android:id="@+id/tv_stat_days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0天"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="累计阅读"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- 竖向分隔线 -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#F0E8E4" />

                <!-- 收藏书籍 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription=""
                        android:src="@drawable/ic_book_small"
                        android:tint="#2196F3" />

                    <TextView
                        android:id="@+id/tv_stat_books"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0本"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="收藏书籍"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 保留旧 IDs 兼容性（hidden） -->
            <TextView android:id="@+id/tv_weekly_time" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tv_weekly_number" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tv_weekly_unit" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tv_sync_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <View android:id="@+id/row_top_cards" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <View android:id="@+id/card_continue_reading" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <View android:id="@+id/card_weekly_time" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tv_continue_title" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tv_continue_progress" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

            <!-- 我的书架 标题行 -->
            <LinearLayout
                android:id="@+id/row_shelf_header"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="我的书架"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_manage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:text="管理"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_sort"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="8dp"
                    android:text="最近阅读 ▼"
                    android:textColor="@color/colorPrimary"
                    android:textSize="13sp" />

            </LinearLayout>

            <com.lcodecore.tkrefreshlayout.TwinklingRefreshLayout
                android:id="@+id/refresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="4dp"
                    android:clipToPadding="false" />

            </com.lcodecore.tkrefreshlayout.TwinklingRefreshLayout>

        </LinearLayout>

        <!-- 书城 Tab -->
        <FrameLayout
            android:id="@+id/container_book_store"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

    <!-- 底部导航 -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:itemIconTint="@color/nav_color_selector"
        app:itemTextColor="@color/nav_color_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
