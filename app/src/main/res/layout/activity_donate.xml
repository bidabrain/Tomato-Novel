<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_activity"
    android:orientation="vertical">

    <!-- Title bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="返回"
            android:padding="8dp"
            android:src="@drawable/img_back"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="支持开发者"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0E8E4" />

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="如果觉得好用，欢迎请我喝杯奶茶 ☕"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="扫描下方微信二维码即可完成支持，感谢！"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <!-- QR code card -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_rounded"
                android:elevation="4dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/iv_qr"
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:contentDescription="捐赠二维码"
                    android:scaleType="fitCenter"
                    android:src="@drawable/payme" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="微信扫一扫"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Save button -->
            <Button
                android:id="@+id/btn_save_qr"
                android:layout_width="260dp"
                android:layout_height="48dp"
                android:layout_marginTop="28dp"
                android:backgroundTint="@color/colorPrimary"
                android:text="保存二维码到相册"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="您的支持是持续开发的最大动力\n感谢每一位用户 ♥"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
